# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
DEBUG=false

# Streamlit API URL Configuration (for remote access)
# When Streamlit is accessed remotely, the browser needs to know how to reach the API
# Priority: EXTERNAL_URL > API_BASE_URL > SERVER_IP > auto-detected IP
# 
# Option 1: Full URL (recommended for production)
# EXTERNAL_URL=http://your-server-ip:8000/api/v1
# EXTERNAL_URL=http://your-domain.com:8000/api/v1
#
# Option 2: Just the IP/hostname (will auto-append :8000/api/v1)
# SERVER_IP=192.168.1.100
# SERVER_IP=your-server-hostname
#
# If not set, Streamlit will auto-detect the local IP (which may be a private IP)
# and remote users won't be able to connect!

# LM Studio Configuration (NEW - Recommended)
# Note: LM_STUDIO_API_KEY must be set - obtain from LM Studio app settings
USE_LM_STUDIO=true
USE_MOCK_SERVICES=false
USE_OLLAMA=false
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_VISION_MODEL=qwen3.6-35b-a3b-uncensored-hauhaucs-aggressive
LM_STUDIO_TEXT_MODEL=qwen3.6-35b-a3b-uncensored-hauhaucs-aggressive
LM_STUDIO_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B-GGUF
LM_STUDIO_EMBEDDING_DIM=4096

# Legacy Model Configuration (for local models - disabled when USE_LM_STUDIO=true)
# Option 1: HuggingFace model IDs (will download on first run)
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct
EMBEDDING_MODEL=openai/clip-vit-large-patch14
LLM_MODEL=meta-llama/Llama-3.2-8B-Instruct

# Option 2: Quantized models (lower VRAM requirements)
# VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct-GPTQ-Int4
# LLM_MODEL=meta-llama/Llama-3.2-8B-Instruct-GPTQ-Int4

# Option 3: Local paths (if models are downloaded locally)
# VLM_MODEL=./models/Qwen2-VL-7B-Instruct
# EMBEDDING_MODEL=./models/clip-vit-large-patch14
# LLM_MODEL=./models/Llama-3.2-8B-Instruct

# Model Inference Settings
VLM_MAX_TOKENS=512
LLM_MAX_TOKENS=1024
TEMPERATURE=0.7
TOP_P=0.9
DEVICE=cuda

# Quantization Settings (for GPTQ/AWQ models)
QUANTIZATION_CONFIG={}

# RAG / ChromaDB Settings
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=manga_covers
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Tag Library
TAG_LIBRARY_PATH=./data/tags.json

# Performance Settings
BATCH_SIZE=1
MAX_CONCURRENT_REQUESTS=1
REQUEST_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
# Use explicit origins for security. Examples:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]
# CORS_ORIGINS=["https://example.com"]
# Leave empty for no CORS headers (most secure)
CORS_ORIGINS=[]

# Development mode
USE_CHINESE_EMBEDDINGS=true

# HuggingFace (optional - for gated models)
# HF_TOKEN=your_huggingface_token_here
